    {
      "field_id": "product",
      "label": "Product",
      "type": "dropdown",
      "required": true,
      "parent_field_id": "geo_location",
      "dropdown_options": []
    },
    {
      "field_id": "environment",
      "label": "Environment",
      "type": "dropdown",
      "required": true,
      "parent_field_id": "product",
      "dropdown_options": []
    },

    {
      "field_id": "queue_name",
      "label": "Queue Name",
      "type": "text",
      "required": true,
      "validation_rules": {
        "regex": "^[a-zA-Z0-9_-]{1,80}(\\.fifo)?$",
        "regex_description": "1-80 chars, alphanumeric, hyphen, underscore. FIFO queues must end with .fifo"
      }
    },

    {
      "field_id": "fifo",
      "label": "FIFO Queue",
      "type": "dropdown",
      "required": true,
      "dropdown_options": [
        { "value": "true" },
        { "value": "false" }
      ]
    },

    {
      "field_id": "dlq",
      "label": "Enable Dead Letter Queue (DLQ)",
      "type": "dropdown",
      "required": true,
      "dropdown_options": [
        { "value": "true" },
        { "value": "false" }
      ]
    },

    {
      "field_id": "max_receive_count",
      "label": "Max Receive Count",
      "type": "number",
      "required": false,
      "active": false,
      "conditional_rules": [
        {
          "if": {
            "field": "dlq",
            "operator": "equals",
            "value": "true"
          },
          "then": {
            "active": true,
            "required": true
          }
        }
      ]
    },

    {
      "field_id": "visibility_timeout",
      "label": "Visibility Timeout (seconds)",
      "type": "number",
      "required": false,
      "validation_rules": {
        "min": 0,
        "max": 43200
      }
    },

    {
      "field_id": "main_retention",
      "label": "Main Queue Retention (seconds)",
      "type": "number",
      "required": false,
      "validation_rules": {
        "min": 60,
        "max": 1209600
      }
    },

    {
      "field_id": "dlq_retention",
      "label": "DLQ Retention (seconds)",
      "type": "number",
      "required": false,
      "active": false,
      "conditional_rules": [
        {
          "if": {
            "field": "dlq",
            "operator": "equals",
            "value": "true"
          },
          "then": {
            "active": true
          }
        }
      ],
      "validation_rules": {
        "min": 60,
        "max": 1209600
      }
    },

    {
      "field_id": "cross_account_ids",
      "label": "Cross Access Account IDs",
      "type": "text",
      "required": false,
      "validation_rules": {
        "regex": "^([0-9]{12})(,[0-9]{12})*$",
        "regex_description": "Comma-separated 12-digit AWS account IDs"
      }
    }
  ]
}

